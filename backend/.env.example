# Server settings
PORT=5000
NODE_ENV=development

# JWT security settings
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Database Settings (PostgreSQL primary)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dress

# Force SQLite mode (true/false) - if true, will bypass PostgreSQL connection checks
FORCE_SQLITE=false

# Cloudinary Settings (Optional - if blank, uploads fall back to local server folder)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:5173
